<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Meal_Card.Pages.Carteira"
             xmlns:view="clr-namespace:Meal_Card.ViewModels"
             xmlns:HistoricoList="clr-namespace:Meal_Card.Models"
             x:DataType="view:CarteiraViewModel"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             Shell.TitleColor="Black"
             BackgroundColor="{StaticResource White}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="Titulo"
                    TargetType="Label">
                <Setter Property="FontAttributes"
                        Value="Bold"/>
                <Setter Property="FontSize"
                        Value="Title"/>
                <Setter Property="FontFamily"
                        Value="PoppinsRegular"/>
                <Setter Property="TextColor"
                        Value="Black"/>
                <Setter Property="Margin"
                        Value="10,10,0,0"/>
            </Style>
            <Style x:Key="Subtitulo"
                    TargetType="Label">
                <Setter Property="FontAttributes"
                        Value="Bold"/>
                <Setter Property="FontSize"
                        Value="18"/>
                <Setter Property="FontFamily"
                        Value="PoppinsRegular"/>
                <Setter Property="TextColor"
                        Value="{StaticResource Gray600}"/>
                <Setter Property="Margin"
                        Value="10,10,0,2"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <RefreshView x:Name="refreshView"
                 VerticalOptions="Fill"
                 HorizontalOptions="Fill"
                 RefreshColor="Blue"
                 Refreshing="Refreshing">
        <ScrollView>
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto"
                    VerticalOptions="Start"
                    Margin="10">

                <VerticalStackLayout Padding="0"
                        Margin="0"
                        Spacing="10"
                        Grid.Row="1">

                    <Grid Grid.Row="1"
                            Grid.Column="2"
                            Grid.ColumnSpan="2"
                            VerticalOptions="Start"
                            Padding="0"
                            Margin="10,0,10,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ImageButton Grid.Row="1"
                                Source="qr_code.png"
                                HeightRequest="20"
                                Padding="10"
                                Margin="10,10,10,0"
                                     WidthRequest="20"
                                ToolTipProperties.Text=" gerar qr code "
                                     HorizontalOptions="Start"
                                VerticalOptions="Start"
                                     x:Name="BtnQrCode"
                                Clicked="BtnQrCode_Clicked"/>

                        <Label Grid.Row="1"
                                Margin="20,20,10,20"
                                HorizontalTextAlignment="End"
                                VerticalTextAlignment="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Saldo: "
                                            TextColor="Black"
                                            FontSize="16"
                                            FontAttributes="Bold"
                                            CharacterSpacing="1"/>
                                    <Span Text="{Binding Saldo}"
                                            TextColor="Green"
                                            FontSize="16"
                                            CharacterSpacing="2"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </Grid>

                    <!-- Cartão Digital -->
                    <Border  StrokeThickness="1"
                            Stroke="Gray"
                            Padding="0"
                            Background="#333C4D"
                             HeightRequest="220"
                            VerticalOptions="Start"
                            Margin="4,-25,4,10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Radius="10"
                                    Brush="Gray"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer x:Name="Card_Payment_NFC"
                                    NumberOfTapsRequired="1"
                                    Tapped="Card_Payment_NFC_Tapped"/>
                        </Border.GestureRecognizers>
                        <!-- Ajuste a altura conforme necessário -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Imagem do Usuário -->

                            <Border Stroke="Transparent"
                                    Background="Transparent"
                                    StrokeThickness="1"
                                    WidthRequest="100"
                                    HeightRequest="100"
                                    Margin="40,20,-10,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="160"/>
                                </Border.StrokeShape>
                                <Image Source="{Binding Imagem}"
                                       Grid.Row="0"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="4"
                                       Aspect="AspectFill"/>


                                <!--Ajuste a posição e tamanho conforme necessário-->
                            </Border>
                            <!-- Quadradinhos no Canto Superior Direito -->
                            <StackLayout Orientation="Horizontal"
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Background="Transparent"
                                         Grid.ColumnSpan="3"
                                    HorizontalOptions="End"
                                    VerticalOptions="Start"
                                    Margin="35,20,35,0">
                                <BoxView Color="Orange"
                                        Margin="5,0,0,0"
                                        WidthRequest="19"
                                        HeightRequest="19"
                                        CornerRadius="5"
                                        BackgroundColor="Transparent"/>
                                <BoxView Color="GreenYellow"
                                        Margin="5,0,0,0"
                                        WidthRequest="19"
                                        HeightRequest="19"
                                        CornerRadius="5"
                                        BackgroundColor="Transparent"/>
                                <BoxView Color="CornflowerBlue"
                                        Margin="5,0,0,0"
                                        WidthRequest="19"
                                        HeightRequest="19"
                                        CornerRadius="5"
                                        BackgroundColor="Transparent"/>
                            </StackLayout>
                            <!-- Nome da Escola e Logo -->
                            <VerticalStackLayout Grid.Row="1"
                                    Grid.Column="2"
                                    Grid.ColumnSpan="3"
                                    HorizontalOptions="End"
                                    Margin="0,-55,10,0">
                                <Label Text="{Binding Acronimo}"
                                        FontSize="16"
                                        TextColor="White"
                                        HorizontalTextAlignment="Center"
                                        FontFamily="PoppinsBold"/>
                                <Label Text="{Binding NomeEscola}"
                                        FontSize="10"
                                        FontFamily="PoppinsBold"
                                       TextColor="FloralWhite"
                                        TextTransform="Default"
                                        HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>

                            <!-- Nome e Número de Cartão do Usuário -->
                            <Grid Grid.Row="2"
                                    Grid.ColumnSpan="5"
                                    BackgroundColor="White"
                                    Padding="10"
                                    Margin="0,-20,0,-45"
                                    HeightRequest="40">
                                <Label Text="{Binding Nome}"
                                        CharacterSpacing="1"
                                        FontAttributes="Bold"
                                        FontSize="14"
                                        TextColor="Black"
                                        HorizontalOptions="Start"
                                        VerticalOptions="Center"
                                        Margin="10,0"/>
                                <Label Text="{Binding CardNumber}"
                                        CharacterSpacing="1"
                                        FontAttributes="Bold"
                                        FontSize="14"
                                        TextColor="Black"
                                        HorizontalOptions="End"
                                        VerticalOptions="Center"
                                        Margin="0,0,20,0"/>
                            </Grid>
                            <!-- Texto Estudante -->
                            <ScrollView Grid.Row="3"
                                    Grid.ColumnSpan="5"
                                    BackgroundColor="Orange"
                                    HeightRequest="40"
                                    VerticalOptions="End">
                                <Label Text="{Binding TipoUtilizador}"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        TextColor="White"
                                        HorizontalTextAlignment="Center"
                                        VerticalTextAlignment="Center"/>
                            </ScrollView>
                        </Grid>
                    </Border>
                    <Border  Stroke="Transparent"
                            Background="Transparent"
                            StrokeThickness="1"
                            Padding="0"
                            Margin="0,-28,0,10"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="2,2,2,2"/>
                        </Border.StrokeShape>
                        <StackLayout Orientation="Horizontal"
                                HorizontalOptions="Center">
                            <ActivityIndicator
                                IsRunning="True"
                                Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Secondary}}"
                                HeightRequest="20"
                                WidthRequest="20"
                                VerticalOptions="Center"
                                HorizontalOptions="Center"/>

                            <Label Text=""
                                   FontSize="30"
                                    Margin="0,0,10,10"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Secondary}}"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"/>

                            <Label Text="{Binding State}"
                                   FontSize="14"
                                   TextColor="Blue"
                                   FontFamily="PoppinsRegular"
                                   VerticalTextAlignment="Center"
                                   HorizontalTextAlignment="Center"/>

                        </StackLayout>
                    </Border>



                    <Grid RowDefinitions="auto, auto" Grid.Row="0"
                            Margin="10,0,0,0">
                        
                        <Label Grid.Row="0"
                               Margin="0,10,0,10" 
                               Text="Atividades Recentes"
                               VerticalOptions="Center"
                               HorizontalOptions="Start"
                               VerticalTextAlignment="Center"
                               HorizontalTextAlignment="Start"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="Gray"
                               FontFamily="PoppinsRegular"/>

                        <Border Grid.Row="0" Margin="0,10,0,10" StrokeShape="RoundRectangle 30" StrokeThickness=".5" Padding="5" WidthRequest="80" VerticalOptions="Center" HorizontalOptions="End">
                            <Label VerticalTextAlignment="Center" HorizontalTextAlignment="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <FormattedString.Spans>
                                            <Span Text="Ver Tudo"
                                              TextColor="Gray"
                                              FontSize="Small"
                                              FontAttributes="Bold"
                                              FontFamily="PoppinsRegular"/>
                                        </FormattedString.Spans>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer NumberOfTapsRequired="1" Tapped="VerHistorico_Tapped"/>
                            </Border.GestureRecognizers>
                        </Border>

                        <CollectionView Grid.Row="1" ItemsSource="{Binding ListItens}">
                            <CollectionView.EmptyView>
                                <Label Text="Sem Registros"
                                        HorizontalTextAlignment="Center"
                                        TextColor="Black"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        VerticalOptions="Center"
                                        x:Name="txt_SemRegistro"/>
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="HistoricoList:HistoricoList">
                                    <Border Margin="0,10,0,0"
                                            Padding="0"
                                            HeightRequest="70"
                                            WidthRequest="320">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8"/>
                                        </Border.StrokeShape>
                                        <Grid Grid.Row="0"
                                                Grid.Column="2"
                                                Grid.ColumnSpan="4"
                                                VerticalOptions="Start"
                                                Margin="10,0">

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <ImageButton Source="{Binding Icon}"
                                                    WidthRequest="30"
                                                    HeightRequest="30"
                                                    HorizontalOptions="Start"
                                                    Margin="0,0,25,0"
                                                    Padding="6"/>

                                            <Label Grid.Row="1"
                                                    Text="{Binding Nome}"
                                                   TextColor="Black"
                                                    FontAttributes="Bold"
                                                   FontSize="12"
                                                    Padding="10"
                                                    Margin="35,0,0,0"
                                                   VerticalOptions="Start"
                                                   HorizontalTextAlignment="Start"/>

                                            <Label Text="{Binding Descricao}"
                                                   TextColor="Black"
                                                   FontSize="10"
                                                    Padding="10"
                                                    Margin="35,0,0,0"
                                                   VerticalOptions="End"
                                                   HorizontalTextAlignment="Start"/>

                                            <Label Text="{Binding valor}"
                                                   TextColor="Black"
                                                   FontSize="12"
                                                    Padding="10"
                                                    Margin="35,18,0,0"
                                                   HorizontalTextAlignment="Start"/>


                                            <Label Text="{Binding Data}"
                                                   TextColor="Black"
                                                   FontSize="10"
                                                    Margin="0,10,0,0"
                                                    Padding="10"
                                                   VerticalOptions="End"
                                                   HorizontalTextAlignment="End"/>

                                            <Border Stroke="Gray"
                                                    StrokeThickness="1"
                                                    Background="Green"
                                                    WidthRequest="100"
                                                    HeightRequest="30"
                                                    HorizontalOptions="End"
                                                    VerticalOptions="Start"
                                                    Margin="10,5,0,40"
                                                    x:Name="BorderState_color">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="50"/>
                                                </Border.StrokeShape>
                                                <Label Text="{Binding status}"
                                                        HorizontalTextAlignment="Center"
                                                        VerticalTextAlignment="Center"
                                                       FontFamily="PoppinsBold"
                                                        TextColor="White"/>
                                            </Border>


                                        </Grid>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                </VerticalStackLayout>
            </Grid>
        </ScrollView>
    </RefreshView>
</ContentPage>