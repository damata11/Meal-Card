<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Meal_Card.Pages.CarteiraPaymentNFC"
             xmlns:model="clr-namespace:Meal_Card.Models"
             xmlns:view="clr-namespace:Meal_Card.ViewModels"
             x:DataType="view:NFCViewModel"  
             Shell.ForegroundColor="Black"
             Shell.TitleColor="Black"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             Shell.BackgroundColor="White"
             BackgroundColor="{DynamicResource White}"
             Title="NFC_Payment">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="Titulo" TargetType="Label">
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="FontSize" Value="Title"/>
                <Setter Property="FontFamily" Value="PoppinsRegular"/>
                <Setter Property="TextColor" Value="{StaticResource Gray600}"/>
                <Setter Property="Margin" Value="10,10,0,0"/>
            </Style>
            <Style x:Key="Subtitulo" TargetType="Label">
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontFamily" Value="PoppinsRegular"/>
                <Setter Property="TextColor" Value="{StaticResource Gray600}"/>
                <Setter Property="Margin" Value="10,10,0,2"/>
            </Style>
            <Style TargetType="Grid">
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Selected">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor"
                                        Value="Transparent" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>
            <Style TargetType="Border">
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Selected">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor"
                                        Value="Transparent" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>


    <RefreshView x:Name="refreshView"
                 VerticalOptions="Fill"
                 HorizontalOptions="Fill"
                 RefreshColor="Blue"
                 Refreshing="Refreshing">

        <Grid RowDefinitions="auto,auto, auto, auto">
            <Grid Grid.Row="0" RowDefinitions="auto, *"  ColumnDefinitions="5*,2*" >
                <Label Grid.Row="0" Grid.Column="0" Style="{StaticResource Subtitulo}" Text="MEAL CARD — EPAMG " VerticalOptions="Center" HorizontalOptions="Start" Margin="20,20,20,0"/>
                <ImageButton  Grid.Row="0" Grid.Column="1" Source="cara.png" WidthRequest="30" VerticalOptions="Center" HeightRequest="30" Padding="6" Margin="0,15,-10,0" x:Name="BtnQRCode"  Clicked="BtnQRCode_Clicked" />
            </Grid>
            <Grid Grid.Row="1" >
                <Border Grid.Row="1" Grid.Column="4" Stroke="Gray" Background="Gray" Padding="1"  HorizontalOptions="Fill" Margin="0,2,0,1" StrokeShape="RoundRectangle 400"  HeightRequest="1" />
            </Grid>

            <!-- Cartão Digital -->
            <Border Grid.Row="2"  StrokeThickness="0" Stroke="Transparent" Padding="0" Background="#333C4D"
                    HeightRequest="200" VerticalOptions="Start" Margin="10,50,10,10" >
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Radius="20" Brush="#ddd"/>
                </Border.Shadow>
                <!-- Ajuste a altura conforme necessário -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Imagem do Usuário -->

                    <Border Stroke="Transparent" Background="Transparent" StrokeThickness="1" WidthRequest="100" HeightRequest="100" Margin="40,20,-10,0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="160"/>
                        </Border.StrokeShape>
                        <Image Source="{Binding Imagem}" 
                               Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4"
                              Aspect="AspectFill" />


                        <!--Ajuste a posição e tamanho conforme necessário-->
                    </Border>
                    <!-- Quadradinhos no Canto Superior Direito -->
                    <StackLayout Orientation="Horizontal" Grid.Row="0" Grid.Column="2" Background="Transparent"
                                 Grid.ColumnSpan="3" HorizontalOptions="End" VerticalOptions="Start" Margin="50,20,50,0">
                        <BoxView Color="Orange" Margin="5,0,0,0" WidthRequest="19" HeightRequest="19" CornerRadius="5" BackgroundColor="Transparent"/>
                        <BoxView Color="GreenYellow" Margin="5,0,0,0" WidthRequest="19" HeightRequest="19" CornerRadius="5" BackgroundColor="Transparent"/>
                        <BoxView Color="CornflowerBlue" Margin="5,0,0,0" WidthRequest="19" HeightRequest="19" CornerRadius="5" BackgroundColor="Transparent"/>
                    </StackLayout>
                    <!-- Nome da Escola e Logo -->
                    <VerticalStackLayout Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="3" HorizontalOptions="End"  Margin="0,-74,15,0" >
                        <Label Text="EPA·MG" FontSize="16"  TextColor="White" HorizontalTextAlignment="Center" FontFamily="PoppinsRegular"/>
                        <Label Text="Escola Profissional e Artística " FontSize="10"
                               TextColor="FloralWhite"  TextTransform="Default" HorizontalTextAlignment="Center" />
                        <Label Text="da Marinha Grande" FontSize="10"
                               TextColor="FloralWhite"  TextTransform="Default" HorizontalTextAlignment="Center"  />
                    </VerticalStackLayout>

                    <!-- Nome e Número de Cartão do Usuário -->
                    <Grid Grid.Row="2" Grid.ColumnSpan="5" BackgroundColor="White" Padding="10" Margin="0,-20,0,-35" HeightRequest="40" >
                        <Label Text="{Binding Nome}" CharacterSpacing="1" FontAttributes="Bold" FontSize="14"  TextColor="Black" HorizontalOptions="Start" VerticalOptions="Center" Margin="10,0"/>
                        <Label Text="{Binding CardNumber}" CharacterSpacing="1" FontAttributes="Bold" FontSize="14" TextColor="Black" HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,20,0"/>
                    </Grid>
                    <!-- Texto Estudante -->
                    <ScrollView Grid.Row="3"  Grid.ColumnSpan="5" BackgroundColor="Orange" HeightRequest="40"  VerticalOptions="End" >
                        <Label Text="{Binding TipoUtilizador}" FontSize="14" FontAttributes="Bold"  TextColor="White" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                    </ScrollView>
                </Grid>
            </Border>
            <Border  Stroke="Transparent"
                            Background="Transparent"
                            StrokeThickness="1"
                            Padding="0"
                            Margin="0,0,0,10"
                            HorizontalOptions="Center"
                     Grid.Row="3">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="2,2,2,2"/>
                </Border.StrokeShape>
                <StackLayout Orientation="Horizontal"
                                HorizontalOptions="Center">
                    <ActivityIndicator
                                IsRunning="True"
                                Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Secondary}}"
                                HeightRequest="20"
                                WidthRequest="20"
                                VerticalOptions="Center"
                                HorizontalOptions="Center"/>

                    <Label Text=""
                                   FontSize="30"
                                    Margin="0,0,10,10"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Secondary}}"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"/>

                    <Label Text="Estou aqui"
                                   FontSize="14"
                                   TextColor="Blue"
                                   FontFamily="PoppinsRegular"
                                   VerticalTextAlignment="Center"
                                   HorizontalTextAlignment="Center"/>

                </StackLayout>
            </Border>
        </Grid>
    </RefreshView>
</ContentPage>