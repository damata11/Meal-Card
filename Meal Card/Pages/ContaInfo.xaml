<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:m="clr-namespace:UraniumUI.Icons.MaterialIcons;assembly=UraniumUI.Icons.MaterialIcons"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             x:Class="Meal_Card.Pages.ContaInfo"
             xmlns:model="clr-namespace:Meal_Card.ViewModels"
             x:DataType="model:AccountViewModel"
             Shell.TitleColor="Black"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             Shell.ForegroundColor="Black"
             BackgroundColor="{DynamicResource White}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="Titulo" TargetType="Label">
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="FontSize" Value="Title"/>
                <Setter Property="FontFamily" Value="PoppinsRegular"/>
                <Setter Property="TextColor" Value="{StaticResource Gray600}"/>
                <Setter Property="Margin" Value="10,10,0,0"/>
            </Style>
            <Style x:Key="Subtitulo" TargetType="Label">
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontFamily" Value="PoppinsRegular"/>
                <Setter Property="TextColor" Value="{StaticResource Gray600}"/>
                <Setter Property="Margin" Value="10,10,0,2"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <RefreshView x:Name="refreshView"
                 VerticalOptions="Fill"
                 HorizontalOptions="Fill"
                 RefreshColor="Blue" 
                 IsRefreshing="{Binding IsRefreshing}"
                 Refreshing="Refreshing">

        <Grid RowDefinitions="auto,auto,auto,*"  RowSpacing="10" Margin="10,20,10,20" >

            <ImageButton  Grid.Row="0" Source="left.png" HorizontalOptions="Start" WidthRequest="20" HeightRequest="20" Padding="8" Margin="10,10" Clicked="BtnVoltar_Clicked" />
            <Label Grid.Row="1" Style="{StaticResource Subtitulo}" Text="Minha Conta" VerticalOptions="Center" Margin="0,-20,0,0" HorizontalOptions="Center"/>
            <Border Grid.Row="2" Grid.Column="4" Stroke="Gray" Background="Gray" Padding="1"  HorizontalOptions="Fill" Margin="5,0,5,20" StrokeShape="RoundRectangle 400"  HeightRequest="1" />

            <ScrollView Grid.Row="3" HorizontalScrollBarVisibility="Never" VerticalScrollBarVisibility="Never" >
                <VerticalStackLayout  Margin="10,20,10,25" Padding="0">
                    <Border Margin="-5,-4,-5,20" Padding="0" Stroke="Transparent" Background="White" HeightRequest="220">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="0,0,20,20"/>
                        </Border.StrokeShape>
                        <Grid Margin="0,20" VerticalOptions="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Stroke="Black" Background="Transparent" StrokeThickness="1" WidthRequest="120" HeightRequest="120" VerticalOptions="Center" HorizontalOptions="Center" Margin="0,20,0,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="120"/>
                                </Border.StrokeShape>

                                <Image 
                                     Source="{Binding Imagem}"
                                     HeightRequest="160"
                                     WidthRequest="160"
                                     Aspect="AspectFill"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"/>

                            </Border>
                            <Grid  VerticalOptions="End" HorizontalOptions="End">
                                <Border Margin="0,-10,110,10" Padding="0" Stroke="Black" Background="White" StrokeThickness="1" HorizontalOptions="End" VerticalOptions="End" ZIndex="10" WidthRequest="35" HeightRequest="35">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="190"/>
                                    </Border.StrokeShape>
                                    
                                    <Image
                                           Source="camera.png"
                                           Aspect="Fill"/>

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer x:Name="TapSelectPhoto" NumberOfTapsRequired="1"  Tapped="TapSelectPhoto_Tapped" />
                                    </Border.GestureRecognizers>
                                </Border>
                            </Grid>

                            <Label Grid.Row="3" x:Name="lblNomeUtilizador"
                                   HorizontalOptions="Center"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   WidthRequest="142"
                                   Margin="10"
                                   HorizontalTextAlignment="Center"
                                   TextColor="Green"/>
                        </Grid>
                    </Border>
                    <Grid Margin="10,20">
                        <Label Text=" Aqui podes visualizar as informações da sua conta. Nota: Essa pagina só serve para visualização das informações da conta, as suas informações são geridas pela escola."  TextColor="Black" HorizontalOptions="Center" FontSize="14"/>
                    </Grid>

                    <material:TextField Title="Nome" Icon="{FontImageSource FontFamily=MaterialRegular, Glyph={x:Static m:MaterialRegular.Account_circle}}" Text="{Binding Nome}"
                                      HorizontalOptions="Fill" TextColor="Black" Margin="5,5,5,10" FontSize="15" BorderColor="{StaticResource Gray100Brush}" TitleColor="{StaticResource Gray600}" AccentColor="Gray" MinimumWidthRequest="120" FontFamily="PoppinsRegular" 
                                        IsEnabled="False"/>


                    <material:TextField Title="Sobrenome" Icon="{FontImageSource FontFamily=MaterialRegular, Glyph={x:Static m:MaterialRegular.Account_circle}}"
                                    Text="{Binding Sobrenome}" HorizontalOptions="Fill" TextColor="Black" Margin="5,10,5,10"   FontSize="15" BorderColor="{StaticResource Gray100Brush}" TitleColor="{StaticResource Gray600}" AccentColor="Gray" MinimumWidthRequest="160" FontFamily="PoppinsRegular" IsEnabled="False" />

                    <material:TextField Title="Email" Icon="{FontImageSource FontFamily=MaterialRegular, Glyph={x:Static m:MaterialRegular.Email}}"
                                    Text="{Binding Email}" HorizontalOptions="Fill" TextColor="Black" Margin="5,10"  FontSize="15" BorderColor="{StaticResource Gray100Brush}" TitleColor="{StaticResource Gray600}" AccentColor="Gray" FontFamily="PoppinsRegular" IsEnabled="False" />

                    <material:TextField Title="Numero do Cartao" Icon="{FontImageSource FontFamily=MaterialRegular, Glyph={x:Static m:MaterialRegular.Credit_card}}"
                                   Text="{Binding CardNumber}" HorizontalOptions="Fill" TextColor="Black" Margin="5,10" FontSize="15" BorderColor="{StaticResource Gray100Brush}" TitleColor="{StaticResource Gray600}" AccentColor="Gray" FontFamily="PoppinsRegular" IsEnabled="False" />


                    <material:TextField  Icon="{FontImageSource FontFamily=MaterialRegular, Glyph={x:Static m:MaterialRegular.School}}"
                                  Text="{Binding Escola}" HorizontalOptions="Fill" TextColor="Black" Margin="5,10" FontSize="15" BorderColor="{StaticResource Gray100Brush}" TitleColor="{StaticResource Gray600}" AccentColor="Gray" FontFamily="PoppinsRegular" IsEnabled="False" />

                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </RefreshView>
</ContentPage>