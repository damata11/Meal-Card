<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:imageEditor="clr-namespace:Syncfusion.Maui.ImageEditor;assembly=Syncfusion.Maui.ImageEditor"
             x:Class="Meal_Card.Pages.CortarImagem"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="White"
             Title="CortarIamgem"
             >
    <Grid RowDefinitions="1*, auto" RowSpacing="10">
        <imageEditor:SfImageEditor Grid.Row="0"
                              x:Name="ImageEditor"
                              ShowToolbar="False"/>

        <Grid Grid.Row="1" ColumnDefinitions="2*,2*" Margin="20,10,20,10" ColumnSpacing="10">
            <Border Grid.Column="0" StrokeThickness=".5" Stroke="#ddd" StrokeShape="RoundRectangle 20" VerticalOptions="Center" HorizontalOptions="End" >
            <Button Grid.Column="0" Text=" Cancelar" Clicked="Cancelar_click" Background="OrangeRed" TextColor="White"/>
            </Border>
            <Border Grid.Column="1"  StrokeShape="RoundRectangle 20" VerticalOptions="Center" HorizontalOptions="End" >
            <Button Grid.Column="1" Text="Salvar" Clicked="Salvar_click" Background="Green" TextColor="White" />
            </Border>
        </Grid>
    </Grid>
</ContentPage>