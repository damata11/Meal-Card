<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Meal_Card.Pages.Inicio"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Collection="clr-namespace:Meal_Card.Models"
    xmlns:models="clr-namespace:Meal_Card.Models"
    xmlns:shimer="clr-namespace:Syncfusion.Maui.Toolkit.Shimmer;assembly=Syncfusion.Maui.Toolkit"
    xmlns:view="clr-namespace:Meal_Card.ViewModels"
    Title="Inicio"
    x:DataType="view:InicioViewModel"
    BackgroundColor="White"
    Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="Titulo" TargetType="Label">
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="FontSize" Value="Title" />
                <Setter Property="FontFamily" Value="PoppinsRegular" />
                <Setter Property="TextColor" Value="{StaticResource Gray600}" />
                <Setter Property="Margin" Value="10,10,0,0" />
            </Style>
            <Style x:Key="Subtitulo" TargetType="Label">
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontFamily" Value="PoppinsRegular" />
                <Setter Property="TextColor" Value="{StaticResource Gray600}" />
                <Setter Property="Margin" Value="10,10,0,2" />
            </Style>
            <Style x:Key="AppTitle" TargetType="Label">
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontFamily" Value="PoppinsRegular" />
                <Setter Property="TextColor" Value="{StaticResource White}" />
                <Setter Property="Margin" Value="10,10,0,2" />
            </Style>
            <Style TargetType="Grid">
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Selected">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>
            <Style TargetType="Border">
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Selected">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>


    <RefreshView
        x:Name="refreshView"
        HorizontalOptions="Fill"
        IsRefreshing="{Binding IsRefreshing}"
        RefreshColor="Blue"
        Refreshing="Refreshing"
        VerticalOptions="Fill">

        <Grid RowDefinitions="auto,auto,auto, *">
            <Grid
                Grid.Row="0"
                Background="Green"
                ColumnDefinitions="5*,2*"
                RowDefinitions="auto, *">
                <Label
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="20,18,20,0"
                    HorizontalOptions="Start"
                    Style="{StaticResource AppTitle}"
                    Text="MEAL CARD — EPAMG "
                    VerticalOptions="Center" />
                <Border
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="0,20,-20,10"
                    HeightRequest="30"
                    HorizontalOptions="Center"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 25"
                    VerticalOptions="Center"
                    WidthRequest="30">
                    <ImageButton
                        x:Name="BtnProfile"
                        Padding="4"
                        Clicked="BtnProfile_Clicked"
                        HeightRequest="25"
                        HorizontalOptions="Center"
                        Source="cara.png"
                        VerticalOptions="Center"
                        WidthRequest="25" />
                </Border>
            </Grid>
            <Grid Grid.Row="1" Background="Green">
                <Border
                    Grid.Row="1"
                    Grid.Column="4"
                    Margin="0,2,0,1"
                    Padding="1"
                    Background="Gray"
                    HeightRequest="1"
                    HorizontalOptions="Fill"
                    Stroke="White"
                    StrokeShape="RoundRectangle 400" />
            </Grid>

            <!--  Carousel  -->
            <Grid
                Grid.Row="2"
                Margin="0"
                BackgroundColor="Beige"
                ZIndex="1">
                <Border StrokeThickness="0">
                    <CarouselView
                        BackgroundColor="White"
                        HeightRequest="200"
                        HorizontalOptions="Fill"
                        IndicatorView="Indicator"
                        ItemsSource="{Binding CarosselItems}"
                        Loop="True"
                        Position="{Binding CurrentPosition, Mode=TwoWay}">
                        <CarouselView.ItemTemplate>
                            <DataTemplate x:DataType="Collection:InicioCarosselList">
                                <Grid RowDefinitions="auto,*,*">

                                    <Image
                                        Grid.Row="0"
                                        Aspect="AspectFill"
                                        HeightRequest="200"
                                        HorizontalOptions="Fill"
                                        Source="{Binding Imagem}"
                                        ZIndex="0" />

                                    <Label
                                        Margin="10,25"
                                        FontFamily="GoogleSans"
                                        FontSize="Body"
                                        HorizontalOptions="Start"
                                        HorizontalTextAlignment="Justify"
                                        Text="{Binding Titulo}"
                                        TextColor="white"
                                        VerticalOptions="End"
                                        VerticalTextAlignment="Justify"
                                        ZIndex="10" />

                                    <Label
                                        Margin="10,10"
                                        FontFamily="GoogleSans"
                                        FontSize="Medium"
                                        HorizontalOptions="Start"
                                        HorizontalTextAlignment="Justify"
                                        Text="{Binding Descrição}"
                                        TextColor="White"
                                        VerticalOptions="End"
                                        VerticalTextAlignment="Justify"
                                        ZIndex="10" />

                                </Grid>
                            </DataTemplate>
                        </CarouselView.ItemTemplate>
                    </CarouselView>
                    <Border.Shadow>
                        <Shadow Brush="Green" Radius="2" />
                    </Border.Shadow>
                </Border>
                <IndicatorView
                    x:Name="Indicator"
                    Margin="0,0,0,10"
                    HorizontalOptions="Center"
                    IndicatorColor="Black"
                    IndicatorSize="5"
                    Opacity=".8"
                    SelectedIndicatorColor="white"
                    VerticalOptions="End" />
            </Grid>

            <!--  Conteúdo principal com scroll  -->
            <ScrollView Grid.Row="3" ZIndex="0">
                <VerticalStackLayout Margin="10,10,10,25" Spacing="20">
                    <Label Margin="10,20,0,0">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span
                                    FontFamily="PoppinsRegular"
                                    FontSize="16"
                                    Text=" Aqui podes ver as informações e os produtos disponiveis na cantina"
                                    TextColor="Black" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <Label Style="{StaticResource Subtitulo}" Text="Categoria dos produtos" />

                    <CollectionView
                        x:Name="CV_Categorias"
                        Background="Transparent"
                        BackgroundColor="Transparent"
                        HeightRequest="240"
                        ItemsSource="{Binding Categorias}"
                        SelectionChanged="Cv_Categorias_SelectionChanged"
                        SelectionMode="Single">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout ItemSpacing="15" Orientation="Horizontal" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Categoria">
                                <Border
                                    Margin="2"
                                    BackgroundColor="White"
                                    HeightRequest="180"
                                    Stroke="Gray"
                                    StrokeShape="RoundRectangle 6"
                                    StrokeThickness="1"
                                    WidthRequest="200">
                                    <Grid
                                        HeightRequest="200"
                                        RowDefinitions="auto,*"
                                        WidthRequest="200">
                                        <Image
                                            Grid.Row="0"
                                            Aspect="AspectFill"
                                            HeightRequest="200"
                                            HorizontalOptions="Fill"
                                            Opacity=".8"
                                            Source="{Binding CaminhoImagem}"
                                            WidthRequest="200"
                                            ZIndex="0" />
                                        <Label
                                            Margin="0,0,0,25"
                                            FontAttributes="Bold"
                                            FontFamily="ArchivoRegular"
                                            FontSize="20"
                                            HorizontalOptions="Center"
                                            HorizontalTextAlignment="Justify"
                                            Text="{Binding Nome}"
                                            TextColor="White"
                                            TextTransform="Uppercase"
                                            VerticalOptions="End"
                                            VerticalTextAlignment="Justify"
                                            ZIndex="10">
                                            <Label.Shadow>
                                                <Shadow
                                                    Brush="#202220"
                                                    Opacity="0.9"
                                                    Radius="1"
                                                    Offset="1,1" />
                                            </Label.Shadow>
                                        </Label>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Border
                        Margin="10,15,10,15"
                        Padding="5"
                        Background="Transparent"
                        HeightRequest="35"
                        HorizontalOptions="Center"
                        Stroke="Gray"
                        StrokeShape="RoundRectangle 30"
                        StrokeThickness=".5"
                        VerticalOptions="Center"
                        WidthRequest="120">
                        <Label HorizontalOptions="Center" VerticalOptions="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span
                                        FontAttributes="Bold"
                                        FontFamily="PoppinsRegular"
                                        FontSize="Medium"
                                        Text="Ver todos"
                                        TextColor="Gray" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer x:Name="ListarTodos" Tapped="ListarTodos_Tapped" />
                        </Border.GestureRecognizers>
                    </Border>

                    <Grid
                        Margin="10,0"
                        HorizontalOptions="Start"
                        VerticalOptions="Center">
                        <Label
                            Margin="0"
                            HorizontalOptions="Start"
                            Style="{StaticResource Subtitulo}"
                            Text="Mais Vendidos"
                            VerticalOptions="Center" />
                    </Grid>

                    <CollectionView
                        x:Name="CV_MaisVendidos"
                        Background="Transparent"
                        BackgroundColor="Transparent"
                        HeightRequest="240"
                        ItemsSource="{Binding ProdutosPlus}"
                        SelectionChanged="Cv_Produto_SelectionChanged"
                        SelectionMode="Single">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout ItemSpacing="5" Orientation="Horizontal" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Produtos_Bar">
                                <Border
                                    Margin="2"
                                    BackgroundColor="White"
                                    HeightRequest="200"
                                    Stroke="Gray"
                                    StrokeShape="RoundRectangle 6"
                                    StrokeThickness="1"
                                    WidthRequest="180">
                                    <Grid
                                        BackgroundColor="White"
                                        HeightRequest="200"
                                        RowDefinitions="auto,auto,auto">

                                        <Border
                                            Grid.Row="0"
                                            HeightRequest="130"
                                            Stroke="Transparent"
                                            StrokeShape="RoundRectangle 6,6,0,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Offset="0" Color="#F8F9FA" />
                                                    <GradientStop Offset="1" Color="#E9ECEF" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Image
                                                Aspect="Fill"
                                                HorizontalOptions="Center"
                                                Source="{Binding CaminhoImagem}"
                                                VerticalOptions="Center" />
                                        </Border>
                                        <StackLayout
                                            Grid.Row="1"
                                            Padding="15"
                                            BackgroundColor="White"
                                            Spacing="5">

                                            <Label
                                                FontAttributes="Bold"
                                                FontFamily="PoppinsSemiBold"
                                                FontSize="14"
                                                HorizontalOptions="Center"
                                                HorizontalTextAlignment="Center"
                                                LineHeight="1.3"
                                                MaxLines="2"
                                                Text="{Binding Nome}"
                                                TextColor="#DD707070"
                                                VerticalOptions="Center"
                                                VerticalTextAlignment="Justify" />

                                            <Label
                                                FontFamily="PoppinsBold"
                                                FontSize="16"
                                                HorizontalOptions="Center"
                                                HorizontalTextAlignment="Center"
                                                Text="{Binding Preco, StringFormat='{}{0:C}'}"
                                                TextColor="#9CF3A107"
                                                VerticalOptions="Center"
                                                VerticalTextAlignment="Justify" />

                                        </StackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Style="{StaticResource Subtitulo}" Text="Produtos Populares" />

                    <CollectionView
                        x:Name="CV_Populares"
                        Background="Transparent"
                        HeightRequest="240"
                        ItemsSource="{Binding ProdutosPopulares}"
                        SelectionChanged="Cv_Produto_SelectionChanged"
                        SelectionMode="Single">

                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout ItemSpacing="15" Orientation="Horizontal" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Produtos_Bar">
                                <!--  Card principal com sombra e estilo  -->
                                <Border
                                    Margin="5"
                                    BackgroundColor="White"
                                    HeightRequest="200"
                                    Stroke="#ddd"
                                    StrokeThickness="1"
                                    WidthRequest="180">
                                    <Border.Shadow>
                                        <Shadow
                                            Brush="#ddd"
                                            Opacity="0.3"
                                            Radius="12"
                                            Offset="0,4" />
                                    </Border.Shadow>
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="6" />
                                    </Border.StrokeShape>

                                    <Grid
                                        BackgroundColor="White"
                                        HeightRequest="200"
                                        RowDefinitions="auto,auto,auto">

                                        <!--  Area da Imagem com borda inferior arredondada  -->
                                        <Border
                                            Grid.Row="0"
                                            HeightRequest="130"
                                            Stroke="Transparent"
                                            StrokeShape="RoundRectangle 6,6,0,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Offset="0" Color="#F8F9FA" />
                                                    <GradientStop Offset="1" Color="#E9ECEF" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Image
                                                Aspect="Fill"
                                                HorizontalOptions="Center"
                                                Source="{Binding CaminhoImagem}"
                                                VerticalOptions="Center" />
                                        </Border>

                                        <!--  Area do Conteúdo  -->
                                        <StackLayout
                                            Grid.Row="1"
                                            Padding="15"
                                            BackgroundColor="White"
                                            Spacing="5">

                                            <!--  Nome do Produto  -->
                                            <Label
                                                FontAttributes="Bold"
                                                FontFamily="PoppinsSemiBold"
                                                FontSize="14"
                                                HorizontalOptions="Center"
                                                HorizontalTextAlignment="Center"
                                                LineHeight="1.3"
                                                MaxLines="2"
                                                Text="{Binding Nome}"
                                                TextColor="#DD707070"
                                                VerticalOptions="Center"
                                                VerticalTextAlignment="Justify" />

                                            <!--  Preço com destaque  -->
                                            <Label
                                                FontFamily="PoppinsBold"
                                                FontSize="16"
                                                HorizontalOptions="Center"
                                                HorizontalTextAlignment="Center"
                                                Text="{Binding Preco, StringFormat='{}{0:C}'}"
                                                TextColor="#9CF3A107"
                                                VerticalOptions="Center"
                                                VerticalTextAlignment="Justify" />
                                        </StackLayout>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </RefreshView>
</ContentPage>
