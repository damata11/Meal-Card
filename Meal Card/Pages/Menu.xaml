<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Meal_Card.Pages.Menu"
             xmlns:view="clr-namespace:Meal_Card.ViewModels"
             x:DataType="view:CarteiraViewModel"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             Shell.TitleColor="Black"
             BackgroundColor="{StaticResource White}"
             Title="Menu">

    <RefreshView x:Name="refreshView"
                 VerticalOptions="Fill"
                 HorizontalOptions="Fill"
                 RefreshColor="Blue"
                 Refreshing="Refreshing">

        <ScrollView>
            <Grid RowDefinitions="auto,auto,1*"
                    RowSpacing="0">

                <ActivityIndicator x:Name="loadIndicator"
                                   IsRunning="False"
                                   IsVisible="False"
                                   Color="Blue"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>

                <Grid Grid.Row="0"
                        Margin="10,20,10,0">
                    <Border Margin="10"
                            Padding="10"
                            Background="Green"
                            Stroke="Gray"
                            StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer NumberOfTapsRequired="1"
                                    x:Name="GoProfile"
                                    Tapped="GoProfile_Tapped"/>
                        </Border.GestureRecognizers>
                        <Grid>
                            <Border WidthRequest="60"
                                    HeightRequest="60"
                                    HorizontalOptions="Start"
                                    Margin="10"
                                    VerticalOptions="Center"
                                    Stroke="White">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="30"/>
                                </Border.StrokeShape>
                                <Image Source="{Binding Imagem}"
                                        WidthRequest="70"
                                        HeightRequest="70"
                                        VerticalOptions="Center"
                                        HorizontalOptions="Center"
                                        Aspect="AspectFill"/>
                            </Border>
                            <VerticalStackLayout VerticalOptions="Center"
                                    HorizontalOptions="Center"
                                    Margin="25,0,0,10">
                                <Label  Text="{Binding Nome}"
                                        FontSize="20"
                                        FontAttributes="Bold"
                                        TextColor="White"
                                        HorizontalTextAlignment="Center"
                                        VerticalTextAlignment="Center"
                                        Margin="20,10,0,0"/>
                                <Label  Text="{Binding Email}"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        TextColor="White"
                                        HorizontalTextAlignment="Center"
                                        VerticalTextAlignment="Center"
                                        Margin="20,0,0,0"/>
                            </VerticalStackLayout>
                        </Grid>
                        <Border.Shadow>
                            <Shadow Radius="30"
                                    Brush="Green"/>
                        </Border.Shadow>
                    </Border>
                </Grid>

                <VerticalStackLayout Grid.Row="1"
                        Margin="2,40,2,0"
                        Padding="8">
                    <Border Grid.Row="0"
                            VerticalOptions="Start"
                            Margin="0,10,0,0"
                            Stroke="{StaticResource Gray100Brush}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Grid Margin="10">
                            <Image Source="calendario.png"
                                    HeightRequest="25"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Start"/>
                            <Label Text="Refeições"
                                   TextColor="Black"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Start"
                                   VerticalOptions="Center"
                                    Margin="40,0,0,0"/>
                            <Image Source="next.png"
                                    HeightRequest="15"
                                    Opacity=".6"
                                    VerticalOptions="Center"
                                    HorizontalOptions="End"/>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer x:Name="TapRefeicao"
                                    Tapped="TapRefeicao_Tapped"/>
                        </Border.GestureRecognizers>
                    </Border>

                    <Border Grid.Row="0"
                            VerticalOptions="Start"
                            Margin="0,10,0,0"
                            Stroke="{StaticResource Gray100Brush}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Grid Margin="10">
                            <Image Source="historico.png"
                                    HeightRequest="25"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Start"/>
                            <Label Text="Historico"
                                   TextColor="Black"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Start"
                                   VerticalOptions="Center"
                                    Margin="40,0,0,0"/>
                            <Image Source="next.png"
                                    HeightRequest="15"
                                    Opacity=".6"
                                    VerticalOptions="Center"
                                    HorizontalOptions="End"/>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer x:Name="TapActivict"
                                    Tapped="Activict_Tapped"/>
                        </Border.GestureRecognizers>
                    </Border>

                    <Border Grid.Row="0"
                            VerticalOptions="Start"
                            Margin="0,10,0,0"
                            Stroke="{StaticResource Gray100Brush}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Grid Margin="10">
                            <Image Source="home_heart.png"
                                    HeightRequest="25"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Start"/>
                            <Label Text="Favoritos"
                                   TextColor="Black"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Start"
                                   VerticalOptions="Center"
                                    Margin="40,0,0,0"/>
                            <Image Source="next.png"
                                    HeightRequest="15"
                                    Opacity=".6"
                                    VerticalOptions="Center"
                                    HorizontalOptions="End"/>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer x:Name="TapFavoritos"
                                    Tapped="Favoritos_Tapped"/>
                        </Border.GestureRecognizers>
                    </Border>



                    <Border Grid.Row="0"
                            VerticalOptions="Start"
                            Margin="0,10,0,0"
                            Stroke="{StaticResource Gray100Brush}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Grid Margin="10">
                            <Image Source="erro.png"
                                    HeightRequest="25"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Start"/>
                            <Label Text="Reportar Falhas"
                                   TextColor="Black"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Start"
                                   VerticalOptions="Center"
                                    Margin="40,0,0,0"/>
                            <Image Source="next.png"
                                    HeightRequest="15"
                                    Opacity=".6"
                                    VerticalOptions="Center"
                                    HorizontalOptions="End"/>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer x:Name="reportar"
                                    Tapped="TapReportarBug_Tapped"/>
                        </Border.GestureRecognizers>
                    </Border>


                    <Label Text="Suporte e Ajuda"
                            TextColor="Black"
                           FontAttributes="Bold"
                           FontSize="18"
                            Margin="8,25,0,10"/>

                    <Border Grid.Row="0"
                            VerticalOptions="Start"
                            Margin="0,10,0,0"
                            Stroke="{StaticResource Gray100Brush}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Grid Margin="10">
                            <Image Source="settings.png"
                                    HeightRequest="25"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Start"/>
                            <Label Text="Perfil"
                                   TextColor="Black"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Start"
                                   VerticalOptions="Center"
                                    Margin="40,0,0,0"/>
                            <Image Source="next.png"
                                    HeightRequest="15"
                                    Opacity=".6"
                                    VerticalOptions="Center"
                                    HorizontalOptions="End"/>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer x:Name="Settings_"
                                    Tapped="Settings_Tapped"/>
                        </Border.GestureRecognizers>
                    </Border>

                    <Border Grid.Row="0"
                            VerticalOptions="Start"
                            Margin="0,10,0,0"
                            Stroke="{StaticResource Gray100Brush}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Grid Margin="10">
                            <Image Source="contact.png"
                                    HeightRequest="25"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Start"/>
                            <Label Text="Contactos"
                                   TextColor="Black"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Start"
                                   VerticalOptions="Center"
                                    Margin="40,0,0,0"/>
                            <Image Source="next.png"
                                    HeightRequest="15"
                                    Opacity=".6"
                                    VerticalOptions="Center"
                                    HorizontalOptions="End"/>

                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer x:Name="TapContacto"
                                    Tapped="TapContacto_Tapped"/>
                        </Border.GestureRecognizers>
                    </Border>

                    <Border Grid.Row="0"
                            VerticalOptions="Start"
                            Margin="0,10,0,0"
                            Stroke="{StaticResource Gray100Brush}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Grid Margin="10">


                            <Image Source="sobre.png"
                                    HeightRequest="25"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Start"/>
                            <Label Text="Sobre a App"
                                   TextColor="Black"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Start"
                                   VerticalOptions="Center"
                                    Margin="40,0,0,0"/>
                            <Image Source="next.png"
                                    HeightRequest="15"
                                    Opacity=".6"
                                    VerticalOptions="Center"
                                    HorizontalOptions="End"/>

                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer x:Name="TapSobre"
                                    Tapped="TapSobre_Tapped"/>
                        </Border.GestureRecognizers>
                    </Border>
                </VerticalStackLayout>
            </Grid>
        </ScrollView>
    </RefreshView>
</ContentPage>