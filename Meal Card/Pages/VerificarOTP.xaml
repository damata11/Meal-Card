<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:Controls="clr-namespace:Meal_Card.Controls"
             xmlns:m="clr-namespace:UraniumUI.Icons.MaterialIcons;assembly=UraniumUI.Icons.MaterialIcons"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             x:Class="Meal_Card.Pages.VerificarOTP"
             Shell.NavBarIsVisible="True"
             Shell.NavBarHasShadow="False"
             Shell.BackgroundColor="Green"
             Shell.ForegroundColor="White"
             Shell.TabBarIsVisible="False"
             BackgroundColor="Green">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="appName" TargetType="Label">
                <Setter Property="FontSize" Value="25" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="HorizontalOptions" Value="Center" />
            </Style>

            <Style x:Key="appImage" TargetType="Image">
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid  VerticalOptions="Start"
          RowDefinitions="Auto,Auto,Auto,Auto,*,Auto"
          HeightRequest="1112" >

        <VerticalStackLayout Grid.Row="0" Margin="0,-10,0,0" Background="Transparent" VerticalOptions="Start">

            <Image Style="{StaticResource appImage}" Margin="0"
                   Aspect="AspectFit"
                   Source="food_login.png"
                   WidthRequest="250"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"
                   />

            <Label Style="{StaticResource appName}" Text=" Verificar OTP "/>

            <Label TextColor="White" Text="Introduza o codigo que recebeste no email" FontSize="16"
                   HorizontalTextAlignment="Center"/>


        </VerticalStackLayout>

        <Border Grid.Row="2" Margin="0,20,0,0" HeightRequest="600" Background="White" VerticalOptions="End">
            <Border.StrokeShape>
                <RoundRectangle  CornerRadius="20,20,0,0"/>
            </Border.StrokeShape>

            <VerticalStackLayout Margin="10,80,10,0">

                <Label Text="Digite o Codigo"
                       CharacterSpacing="0.5"
                       Margin="18,0,0,0"
                       Padding="0"
                       FontSize="15"
                       FontAttributes="Bold"/>

                <material:TextField Title=" E-mail" Icon="{FontImageSource FontFamily=MaterialRegular, Glyph={x:Static m:MaterialRegular.Email},Color={StaticResource Gray900}}" x:Name="txt_OTP" HorizontalOptions="Fill" TextChanged="OTP_TextChanged" TextColor="Black" Margin="30,0,30,20"  FontSize="15" BorderColor="Black" TitleColor="Black" AccentColor="Black" FontFamily="PoppinsRegular" SelectionHighlightColor="Black"/>

                <Label HorizontalTextAlignment="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Não recebeu o codigo ?" TextColor="Black" FontFamily="PoppinsRegular"/>
                            <Span Text=" Enviar novamente." TextColor="Blue" FontFamily="PoppinsRegular">
                                <Span.GestureRecognizers>
                                    <TapGestureRecognizer NumberOfTapsRequired="1" Tapped="TapEnviar_Tapped"/>
                                </Span.GestureRecognizers>
                            </Span>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>


                <Controls:ButtonControl
                    Text="Verificar"
                    x:Name="lbl_registrar"
                    TextColor="White"
                    CharacterSpacing="1"
                    HeightRequest="50"
                    Margin="10"
                    FontFamily="Anton"
                    Background="Green"
                    Stroke="gray"
                    HorizontalOptions="Fill"/>

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>